#!/bin/bash
# orchestra — CLI for managing autonomous Claude Code workflows.
# Spec: docs/superpowers/specs/2026-04-29-orchestra-cleanup-design.md
#
# Subcommands:
#   init     — Scaffold .orchestra/ in current dir
#   run      — Start an orchestra run
#   status   — Show current run state
#   test     — Run smoke test
#   reset    — Archive in-progress run state and reset
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="$SCRIPT_DIR/../lib"

usage() {
    cat <<EOF
Usage: orchestra <command> [args]

Commands:
  init [dir]   Scaffold .orchestra/ state files in target directory
  run          Start an orchestra run (uses .orchestra/CONFIG.md + OBJECTIVE.md)
  status       Show current run state
  test         Run end-to-end smoke test
  reset        Archive current run state, reset for next

All run parameters live in .orchestra/CONFIG.md — no env vars, no CLI args.
EOF
}

die() { echo "ERROR: $1" >&2; exit 1; }

cmd_init() {
    local target="${1:-.}"
    target="$(cd "$target" 2>/dev/null && pwd)" || die "Directory does not exist: ${1:-.}"

    # Must be a git repo (no auto-init per spec Section 12 step 2)
    git -C "$target" rev-parse --show-toplevel >/dev/null 2>&1 \
        || die "$target is not a git repository. If this is intentional, run 'git init' first then retry."

    # inotify-tools preflight (Linux-only target per spec Section 11.C)
    command -v inotifywait >/dev/null 2>&1 \
        || die "inotify-tools not installed — run 'apt-get install inotify-tools' (Ubuntu/Debian) or your distro's equivalent"

    local orch="$target/.orchestra"
    mkdir -p "$orch/runtime/bin" "$orch/runtime/lib" "$orch/runs/archive"

    # Copy runtime files. Source paths relative to this script's location.
    cp "$SCRIPT_DIR/orchestra"          "$orch/runtime/bin/orchestra"
    chmod +x "$orch/runtime/bin/orchestra"
    # orchestrator.sh is added in Phase 4; copy if it exists, otherwise skip silently
    if [ -f "$SCRIPT_DIR/orchestrator.sh" ]; then
        cp "$SCRIPT_DIR/orchestrator.sh" "$orch/runtime/bin/orchestrator.sh"
        chmod +x "$orch/runtime/bin/orchestrator.sh"
    fi
    cp "$LIB_DIR/config.sh" "$orch/runtime/lib/config.sh"
    cp "$LIB_DIR/winddown-prompt.txt" "$orch/runtime/lib/winddown-prompt.txt"

    # Copy templates only if missing — never overwrite user content.
    # Each entry: "<template-filename>:<dest-filename>". Most are identity;
    # orchestra-CLAUDE.md is renamed to CLAUDE.md so the source template
    # filename doesn't collide with the project's own CLAUDE.md template.
    local TEMPLATE_DIR="$SCRIPT_DIR/../templates"
    for pair in "CONFIG.md:CONFIG.md" "OBJECTIVE.md:OBJECTIVE.md" "orchestra-CLAUDE.md:CLAUDE.md"; do
        local src="${pair%:*}" dst="${pair#*:}"
        if [ ! -f "$orch/$dst" ]; then
            cp "$TEMPLATE_DIR/$src" "$orch/$dst"
            echo "  Created .orchestra/$dst"
        else
            echo "  Skipped .orchestra/$dst (already exists)"
        fi
    done

    cat <<EOF

Done. Next steps:
  1. Edit .orchestra/CONFIG.md — set MAX_SESSIONS, MODEL, WORKTREE_BASE, BASE_BRANCH
  2. Edit .orchestra/OBJECTIVE.md with the brief for your first run
  3. Commit .orchestra/CONFIG.md and .orchestra/OBJECTIVE.md to your base branch
  4. Run: .orchestra/runtime/bin/orchestra run
EOF
}
cmd_run() {
    local project_dir
    project_dir="$(git rev-parse --show-toplevel 2>/dev/null)" || die "Not in a git repository"
    local orch="$project_dir/.orchestra"
    [ -d "$orch" ] || die ".orchestra/ not found. Run 'orchestra init' first."

    # Load + validate config (sourced from RUNTIME copy, not source-tree)
    declare -gA ORCHESTRA_CONFIG
    # shellcheck source=/dev/null
    source "$orch/runtime/lib/config.sh"
    parse_config_md "$orch/CONFIG.md" || die "CONFIG.md parse failed"
    apply_config_defaults
    validate_config || die "CONFIG.md validation failed"

    local base_branch="${ORCHESTRA_CONFIG[BASE_BRANCH]}"
    local worktree_base="${ORCHESTRA_CONFIG[WORKTREE_BASE]}"
    local tmux_prefix="${ORCHESTRA_CONFIG[TMUX_PREFIX]}"

    mkdir -p "$worktree_base"

    # Atomic mkdir gate (spec Section 7) — retry up to 3x with fresh timestamp
    local run_ts run_dir attempt=0
    local run_folder_root="$orch/runs"
    while [ $attempt -lt 3 ]; do
        run_ts="$(date -u +%Y%m%d-%H%M%S)"
        run_dir="$run_folder_root/$run_ts"
        if mkdir "$run_dir" 2>/dev/null; then
            break
        fi
        attempt=$((attempt + 1))
        sleep 1
    done
    [ $attempt -lt 3 ] || die "Could not allocate a unique run timestamp after 3 attempts"

    local worktree_dir="$worktree_base/run-$run_ts"
    local tmux_name="$tmux_prefix-$run_ts"
    local run_branch="orchestra/run-$run_ts"

    # Setup-cleanup trap — clears the run folder if anything below fails before
    # the session loop is live (spec Section 7). ERR only — EXIT/INT/TERM are
    # reserved for the wind-down lock trap (Section 6.1).
    trap "rm -rf '$run_dir'" ERR

    # Worktree creation
    git -C "$project_dir" worktree add "$worktree_dir" -b "$run_branch" "$base_branch" \
        || die "git worktree add failed"

    # Preflight: OBJECTIVE.md must exist in the worktree (per spec Section 4)
    [ -f "$worktree_dir/.orchestra/OBJECTIVE.md" ] \
        || die "OBJECTIVE.md not found in worktree — commit it to $base_branch and retry."

    # Build the run folder INSIDE the worktree (per spec Section 5)
    local wt_run_dir="$worktree_dir/.orchestra/runs/$run_ts"
    mkdir -p "$wt_run_dir/9-sessions"
    cp "$worktree_dir/.orchestra/OBJECTIVE.md" "$wt_run_dir/2-OBJECTIVE.md"
    : > "$wt_run_dir/1-INBOX.md"
    : > "$wt_run_dir/3-TODO.md"
    : > "$wt_run_dir/4-DECISIONS.md"
    : > "$wt_run_dir/5-CHANGELOG.md"
    : > "$wt_run_dir/6-HANDOVER.md"
    : > "$wt_run_dir/7-SUMMARY.md"

    # Tmux conflict check
    if tmux has-session -t "$tmux_name" 2>/dev/null; then
        die "tmux session '$tmux_name' already exists — kill it or wait"
    fi

    # Clear setup trap — past this point the run folder legitimately persists
    trap - ERR

    # Launch
    echo "Starting orchestra run in tmux session '$tmux_name'..."
    echo "  Worktree: $worktree_dir"
    echo "  Run dir:  $wt_run_dir"
    echo "  Attach:   tmux attach -t $tmux_name"

    # Use tmux -e for env passing and -c for cwd to avoid building a shell
    # command-string with interpolated quotes (no injection vector even if
    # config values contain shell metacharacters).
    tmux new-session -d -s "$tmux_name" -c "$worktree_dir" \
        -e "RUN_DIR=$wt_run_dir" \
        -e "WORKTREE_DIR=$worktree_dir" \
        -e "RUN_TS=$run_ts" \
        -e "RUN_BRANCH=$run_branch" \
        -e "BASE_BRANCH=$base_branch" \
        bash "$orch/runtime/bin/orchestrator.sh"
}
cmd_status() {
    local project_dir
    project_dir="$(git rev-parse --show-toplevel 2>/dev/null)" || die "Not in a git repository"
    local orch="$project_dir/.orchestra"
    [ -d "$orch" ] || die ".orchestra/ not found. Run 'orchestra init' first."

    declare -gA ORCHESTRA_CONFIG
    # shellcheck source=/dev/null
    source "$orch/runtime/lib/config.sh"
    parse_config_md "$orch/CONFIG.md" || die "CONFIG.md parse failed"
    apply_config_defaults

    local worktree_base="${ORCHESTRA_CONFIG[WORKTREE_BASE]:-}"
    local tmux_prefix="${ORCHESTRA_CONFIG[TMUX_PREFIX]}"

    [ -n "$worktree_base" ] || die "WORKTREE_BASE not set in CONFIG.md"

    echo "Active runs:"

    # Iterate gate folders at <project>/.orchestra/runs/<ts>/, skipping archive/.
    # Use find to avoid pipefail/ls trap when no entries exist.
    local gate_dirs
    gate_dirs=$(find "$orch/runs" -mindepth 1 -maxdepth 1 -type d -not -name archive 2>/dev/null | sort)

    local printed_any=0
    if [ -n "$gate_dirs" ]; then
        local gate
        while IFS= read -r gate; do
            [ -n "$gate" ] || continue
            local run_ts
            run_ts="$(basename "$gate")"
            local wt_run_dir="$worktree_base/run-$run_ts/.orchestra/runs/$run_ts"
            local tmux_name="$tmux_prefix-$run_ts"
            local state

            # Marker presence is authoritative — checked BEFORE tmux liveness.
            if [ -f "$wt_run_dir/BLOCKED" ]; then
                state="BLOCKED"
            elif [ -f "$wt_run_dir/WIND-DOWN-FAILED" ]; then
                state="WIND-DOWN-FAILED"
            elif [ ! -d "$wt_run_dir" ]; then
                # Run dir was moved into archive — treat as archived.
                state="archived"
            elif tmux has-session -t "$tmux_name" 2>/dev/null; then
                state="active (tmux: $tmux_name)"
            else
                state="stale"
            fi

            echo "  $run_ts: $state"
            printed_any=1
        done <<< "$gate_dirs"
    fi

    if [ "$printed_any" -eq 0 ]; then
        echo "  (no active runs)"
    fi

    # Count archived runs across all worktrees.
    local archived_count=0
    if [ -d "$worktree_base" ]; then
        archived_count=$(find "$worktree_base" -mindepth 5 -maxdepth 5 -type d -path '*/runs/archive/*' 2>/dev/null | wc -l)
    fi
    echo ""
    echo "Archived runs: $archived_count"
}

smoke_assert_common() {
    local tmpdir="$1"
    local archive

    # `find` over globbed `ls` because under set -euo pipefail an `ls` with
    # no matching glob exits 2, pipefail propagates, and set -e aborts the
    # script with a silent exit 2 BEFORE the die message can fire. find
    # returns 0 with empty output on no matches, so the assertion message
    # is what surfaces on failure.
    #
    # Path layout (depths measured from $tmpdir/wt):
    #   wt/run-<ts>                              = depth 1
    #   wt/run-<ts>/.orchestra/runs              = depth 3
    #   wt/run-<ts>/.orchestra/runs/<ts>         = depth 4   (active)
    #   wt/run-<ts>/.orchestra/runs/archive      = depth 4
    #   wt/run-<ts>/.orchestra/runs/archive/<ts> = depth 5   (archived)
    archive=$(find "$tmpdir"/wt -mindepth 5 -maxdepth 5 -type d -path '*/runs/archive/*' -print -quit 2>/dev/null)
    [ -n "$archive" ] || die "ASSERT FAIL: no archived run found"

    for f in 1-INBOX.md 2-OBJECTIVE.md 3-TODO.md 4-DECISIONS.md 5-CHANGELOG.md \
             6-HANDOVER.md 7-SUMMARY.md 9-sessions; do
        [ -e "$archive/$f" ] || die "ASSERT FAIL: missing $f in archive"
    done

    # Active run dirs are at depth 4 directly under runs/ but NOT named archive.
    # On a successful wind-down, the run dir was moved to archive/<ts>, so this
    # count must be 0.
    local active_count
    active_count=$(find "$tmpdir"/wt -mindepth 4 -maxdepth 4 -type d -path '*/.orchestra/runs/*' -not -name archive 2>/dev/null | wc -l)
    [ "$active_count" -eq 0 ] || die "ASSERT FAIL: active run folder remains (should be archived)"
}

smoke_assert_empty() {
    local tmpdir="$1"
    local wt
    wt=$(ls -d "$tmpdir"/wt/run-* | head -1)

    local found
    found=$(find "$wt" -maxdepth 1 \( -name 'TODO*' -o -name 'DECISIONS*' -o -name 'CHANGELOG*' \) | wc -l)
    [ "$found" -eq 0 ] || die "ASSERT FAIL: empty fixture should not have parent governance"

    [ "$(cat "$wt/file-a.txt" 2>/dev/null)" = "alpha" ] || die "ASSERT FAIL: file-a.txt"
    [ "$(cat "$wt/file-b.txt" 2>/dev/null)" = "beta" ] || die "ASSERT FAIL: file-b.txt"
}

smoke_assert_with_governance() {
    local tmpdir="$1"
    local wt
    # Pick the (single) worktree directly with find — no glob/ls/pipefail trap.
    wt=$(find "$tmpdir/wt" -mindepth 1 -maxdepth 1 -type d -name 'run-*' -print -quit 2>/dev/null)
    [ -n "$wt" ] || die "ASSERT FAIL: no worktree found"

    # Each parent file: original [fixture-original] entry preserved + correct marker present
    grep -q '\[fixture-original\] T001' "$wt/TODO.md"     || die "ASSERT FAIL: TODO.md original lost"
    grep -q '\[smoke-todo\]'              "$wt/TODO.md"     || die "ASSERT FAIL: TODO.md missing [smoke-todo] marker"

    grep -q '\[fixture-original\] D001' "$wt/DECISIONS.md" || die "ASSERT FAIL: DECISIONS.md original lost"
    grep -q '\[smoke-decision\]'          "$wt/DECISIONS.md" || die "ASSERT FAIL: DECISIONS.md missing [smoke-decision] marker"

    grep -q '\[fixture-original\] C001' "$wt/CHANGELOG.md" || die "ASSERT FAIL: CHANGELOG.md original lost"
    grep -q '\[smoke-changelog\]'         "$wt/CHANGELOG.md" || die "ASSERT FAIL: CHANGELOG.md missing [smoke-changelog] marker"

    # No marker leaked into the wrong file.
    ! grep -q '\[smoke-decision\]'  "$wt/TODO.md"      || die "ASSERT FAIL: [smoke-decision] leaked into TODO.md"
    ! grep -q '\[smoke-changelog\]' "$wt/TODO.md"      || die "ASSERT FAIL: [smoke-changelog] leaked into TODO.md"
    ! grep -q '\[smoke-todo\]'      "$wt/DECISIONS.md" || die "ASSERT FAIL: [smoke-todo] leaked into DECISIONS.md"
    ! grep -q '\[smoke-changelog\]' "$wt/DECISIONS.md" || die "ASSERT FAIL: [smoke-changelog] leaked into DECISIONS.md"
    ! grep -q '\[smoke-todo\]'      "$wt/CHANGELOG.md" || die "ASSERT FAIL: [smoke-todo] leaked into CHANGELOG.md"
    ! grep -q '\[smoke-decision\]'  "$wt/CHANGELOG.md" || die "ASSERT FAIL: [smoke-decision] leaked into CHANGELOG.md"

    # Wind-down per-file commits visible on the merged base branch. Use literal
    # arrow U+2192 to match the prompt's commit-message convention.
    (
        cd "$wt"
        git log --grep "wind-down: ingest 3-TODO.md →"      --format=%H | grep -q . || die "ASSERT FAIL: missing TODO ingest commit"
        git log --grep "wind-down: ingest 4-DECISIONS.md →" --format=%H | grep -q . || die "ASSERT FAIL: missing DECISIONS ingest commit"
        git log --grep "wind-down: ingest 5-CHANGELOG.md →" --format=%H | grep -q . || die "ASSERT FAIL: missing CHANGELOG ingest commit"
    )

    # Work products from the OBJECTIVE.
    [ "$(cat "$wt/file-a.txt" 2>/dev/null)" = "alpha" ] || die "ASSERT FAIL: file-a.txt"
    [ "$(cat "$wt/file-b.txt" 2>/dev/null)" = "beta" ]  || die "ASSERT FAIL: file-b.txt"
}

smoke_assert_with_conflict() {
    local tmpdir="$1"
    local wt archive
    wt=$(find "$tmpdir/wt" -mindepth 1 -maxdepth 1 -type d -name 'run-*' -print -quit 2>/dev/null)
    [ -n "$wt" ] || die "ASSERT FAIL: no worktree found"

    # 7-SUMMARY.md lives in the archived run folder. smoke_assert_common
    # already verified its existence; re-locate here.
    archive=$(find "$tmpdir/wt" -mindepth 5 -maxdepth 5 -type d -path '*/runs/archive/*' -print -quit 2>/dev/null)
    [ -n "$archive" ] || die "ASSERT FAIL: no archived run found"

    # Conflict surfaced in 7-SUMMARY.md per spec Section 6.3 step 4a schema.
    local summary="$archive/7-SUMMARY.md"
    grep -q "Potential governance conflicts" "$summary" \
        || die "ASSERT FAIL: 7-SUMMARY.md missing 'Potential governance conflicts' subsection"
    grep -qE '###[[:space:]]+Conflict' "$summary" \
        || die "ASSERT FAIL: 7-SUMMARY.md has no '### Conflict' entry"
    grep -qE 'Source:.*4-DECISIONS' "$summary" \
        || die "ASSERT FAIL: conflict Source not labelled 4-DECISIONS.md"
    grep -qE 'Target:.*DECISIONS\.md' "$summary" \
        || die "ASSERT FAIL: conflict Target not labelled DECISIONS.md"

    # Append-only invariant: original SQLite decision still present, new
    # Postgres decision appended.
    grep -q '\[fixture-original\] D001.*SQLite' "$wt/DECISIONS.md" \
        || die "ASSERT FAIL: original [fixture-original] D001 (SQLite) lost from DECISIONS.md"
    grep -qE '\[smoke-decision\].*Postgres' "$wt/DECISIONS.md" \
        || die "ASSERT FAIL: new [smoke-decision] (Postgres) missing from DECISIONS.md"

    # Wind-down ingestion commit for DECISIONS still landed on the base.
    (
        cd "$wt"
        git log --grep "wind-down: ingest 4-DECISIONS.md →" --format=%H | grep -q . \
            || die "ASSERT FAIL: missing DECISIONS ingest commit"
    )
}

cmd_test() {
    local variant="${1:-empty}"
    case "$variant" in
        empty|with-governance|with-conflict) ;;
        *) die "Unknown smoke-test variant: $variant (use 'empty', 'with-governance', or 'with-conflict')" ;;
    esac

    command -v claude >/dev/null 2>&1 \
        || die "claude CLI not found on PATH; smoke test needs real Claude"

    local fixture="$SCRIPT_DIR/../examples/smoke-test/$variant"
    [ -d "$fixture" ] || die "Fixture not found: $fixture"

    local tmpdir
    tmpdir="${TMPDIR:-/tmp}/orchestra-smoke-$(date -u +%Y%m%d-%H%M%S)-$variant"
    rm -rf "$tmpdir"
    mkdir -p "$tmpdir"
    cp -r "$fixture/." "$tmpdir/"

    cd "$tmpdir"
    git init -q --initial-branch=master

    # Local bare remote so wind-down's `git push origin master` has a target.
    # The fixture has no real remote; without this, push fails and the run BLOCKs.
    # Pin --initial-branch=master so the bare HEAD matches BASE_BRANCH (otherwise
    # the bare repo's symbolic HEAD inherits the user's git default, often "main").
    local bare="$tmpdir/origin.git"
    git init -q --bare --initial-branch=master "$bare"
    git remote add origin "$bare"

    git -c user.email=smoke@test -c user.name=smoke add -A
    git -c user.email=smoke@test -c user.name=smoke commit -q -m "smoke-test fixture init"
    git -c user.email=smoke@test -c user.name=smoke push -q origin master

    "$SCRIPT_DIR/orchestra" init . >/dev/null

    cat > .orchestra/CONFIG.md <<EOF
- \`MAX_SESSIONS\`: 2
- \`MAX_CONSECUTIVE_CRASHES\`: 1
- \`MODEL\`: opus
- \`WORKTREE_BASE\`: $tmpdir/wt
- \`BASE_BRANCH\`: master
- \`TMUX_PREFIX\`: orch-smoke
- \`SMOKE_TEST_TIMEOUT\`: 900
EOF

    cp OBJECTIVE.md .orchestra/OBJECTIVE.md

    git -c user.email=smoke@test -c user.name=smoke add -A
    git -c user.email=smoke@test -c user.name=smoke commit -q -m "smoke-test config + objective"
    git -c user.email=smoke@test -c user.name=smoke push -q origin master

    .orchestra/runtime/bin/orchestra run

    # Poll for the run worktree to appear, then poll for its tmux session to end.
    local elapsed=0 timeout=900 worktree="" run_ts=""
    while [ $elapsed -lt $timeout ]; do
        if [ -z "$worktree" ]; then
            worktree=$(ls -d "$tmpdir"/wt/run-* 2>/dev/null | head -1 || true)
            if [ -n "$worktree" ]; then
                run_ts="${worktree##*/run-}"
            fi
        fi
        if [ -n "$run_ts" ]; then
            tmux has-session -t "orch-smoke-$run_ts" 2>/dev/null || break
        fi
        sleep 10
        elapsed=$((elapsed + 10))
    done

    if [ $elapsed -ge $timeout ]; then
        tmux kill-session -t "orch-smoke-$run_ts" 2>/dev/null || true
        die "Smoke test timed out after ${timeout}s"
    fi

    smoke_assert_common "$tmpdir"
    case "$variant" in
        empty)            smoke_assert_empty "$tmpdir" ;;
        with-governance)  smoke_assert_with_governance "$tmpdir" ;;
        with-conflict)    smoke_assert_with_conflict "$tmpdir" ;;
    esac

    echo ""
    echo "Smoke test PASSED ($variant). Tempdir: $tmpdir"
}

cmd_reset() {
    local project_dir
    project_dir="$(git rev-parse --show-toplevel 2>/dev/null)" || die "Not in a git repository"
    local orch="$project_dir/.orchestra"
    [ -d "$orch" ] || die ".orchestra/ not found. Run 'orchestra init' first."

    declare -gA ORCHESTRA_CONFIG
    # shellcheck source=/dev/null
    source "$orch/runtime/lib/config.sh"
    parse_config_md "$orch/CONFIG.md" || die "CONFIG.md parse failed"
    apply_config_defaults

    local worktree_base="${ORCHESTRA_CONFIG[WORKTREE_BASE]:-}"
    [ -n "$worktree_base" ] || die "WORKTREE_BASE not set in CONFIG.md"

    local archived=0

    # For each worktree, archive any non-archive run dirs.
    if [ -d "$worktree_base" ]; then
        local worktrees
        worktrees=$(find "$worktree_base" -mindepth 1 -maxdepth 1 -type d -name 'run-*' 2>/dev/null)
        local wt
        while IFS= read -r wt; do
            [ -n "$wt" ] || continue
            local runs_dir="$wt/.orchestra/runs"
            [ -d "$runs_dir" ] || continue

            # Active run dirs at <wt>/.orchestra/runs/<ts>/ (siblings of archive/).
            local active_runs
            active_runs=$(find "$runs_dir" -mindepth 1 -maxdepth 1 -type d -not -name archive 2>/dev/null)
            local run
            while IFS= read -r run; do
                [ -n "$run" ] || continue
                local run_ts
                run_ts="$(basename "$run")"
                mkdir -p "$runs_dir/archive"
                mv "$run" "$runs_dir/archive/$run_ts"
                archived=$((archived + 1))
            done <<< "$active_runs"

            # Remove stale wind-down lock if any.
            if [ -f "$wt/.orchestra/.wind-down.lock" ]; then
                rm -f "$wt/.orchestra/.wind-down.lock"
            fi
        done <<< "$worktrees"
    fi

    # Clean up project-tree gate folders (only if empty — they're just gate dirs).
    local gate_dirs
    gate_dirs=$(find "$orch/runs" -mindepth 1 -maxdepth 1 -type d -not -name archive 2>/dev/null)
    local gate
    while IFS= read -r gate; do
        [ -n "$gate" ] || continue
        rmdir "$gate" 2>/dev/null || true
    done <<< "$gate_dirs"

    echo "Reset: $archived run folder(s) archived."
}

cmd="${1:-}"
[[ $# -gt 0 ]] && shift
case "$cmd" in
    init)      cmd_init "$@" ;;
    run|start) cmd_run "$@" ;;
    status)    cmd_status "$@" ;;
    test)      cmd_test "$@" ;;
    reset)     cmd_reset "$@" ;;
    -h|--help|help|"") usage; exit 0 ;;
    *) echo "Unknown command: $cmd" >&2; usage >&2; exit 1 ;;
esac
