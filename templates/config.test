# .orchestra/config.test — Orchestra integration test configuration
#
# Invoked by `orchestra test`. Self-contained: all governance files for the
# test live under .orchestra/test/. The real TODO.md / DECISIONS.md /
# CHANGELOG.md / HANDOVER.md / INBOX.md are NOT touched.
#
# Test fixtures are committed to the repo so worktrees inherit them.
# Before each test run, .orchestra/test/ is reset to a known-clean state.

# ─── Task Queue ──────────────────────────────────────────────────────────────
TASKS=T9998,T9999

# ─── Session Limits ──────────────────────────────────────────────────────────
MAX_SESSIONS=3
MAX_CONSECUTIVE_CRASHES=2

# ─── Quota Pacing ────────────────────────────────────────────────────────────
QUOTA_PACING=true
QUOTA_THRESHOLD=80
QUOTA_POLL_INTERVAL=120

# ─── Cooldowns (seconds) ─────────────────────────────────────────────────────
COOLDOWN_SECONDS=3
CRASH_COOLDOWN_SECONDS=3

# ─── Model ───────────────────────────────────────────────────────────────────
MODEL=opus
EFFORT=high

# ─── Test Governance Paths ───────────────────────────────────────────────────
# Self-contained under .orchestra/test/ — does not touch real governance files
TODO_FILE=.orchestra/test/TODO/TODO.md
DECISIONS_FILE=.orchestra/test/Decisions/DECISIONS.md
CHANGELOG_FILE=.orchestra/test/Changelog/CHANGELOG.md

# ─── Protocol ────────────────────────────────────────────────────────────────
DEVELOPMENT_PROTOCOL=DEVELOPMENT-PROTOCOL.md

# ─── Toolchain ───────────────────────────────────────────────────────────────
TOOLCHAIN_FILE=.orchestra/toolchain.md

# ─── Worktree ────────────────────────────────────────────────────────────────
WORKTREE_BASE=/tmp/orchestra-test

# ─── Tmux ────────────────────────────────────────────────────────────────────
TMUX_SESSION=orchestra-test

# ─── State Dir Override ──────────────────────────────────────────────────────
# The orchestrator reads HANDOVER.md and INBOX.md from STATE_DIR (default
# .orchestra/). For test mode, point it at .orchestra/test/ so we use the
# test versions, not the live ones.
STATE_DIR=.orchestra/test
